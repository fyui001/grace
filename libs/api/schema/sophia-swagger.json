{
  "openapi": "3.0.1",
  "info": {
    "title": "Sophia.Api",
    "version": "1.0"
  },
  "paths": {
    "/api/user": {
      "get": {
        "tags": [
          "GetUserAction"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponseBaseResponder"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponseBaseResponder"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponseBaseResponder"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/user/register": {
      "post": {
        "tags": [
          "RegisterUserAction"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterUserRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponseBaseResponder"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponseBaseResponder"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponseBaseResponder"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "409": {
            "description": "Conflict"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RegisterUserRequest": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 255,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "iconUrl": {
            "type": "string",
            "nullable": true
          },
          "isRegistered": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "UserResponseBaseResponder": {
        "type": "object",
        "properties": {
          "status": {
            "type": "boolean"
          },
          "message": {
            "type": "string",
            "nullable": true
          },
          "errors": {
            "nullable": true
          },
          "data": {
            "$ref": "#/components/schemas/UserResponse"
          }
        },
        "additionalProperties": false
      }
    }
  }
}