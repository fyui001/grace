{
  "name": "grace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . && yarn run prettier:check",
    "prettier": "prettier --write --ignore-path .gitignore './**/*.{js,jsx,ts,tsx,json,css}'",
    "prettier:check": "prettier --check --ignore-path .gitignore './**/*.{js,jsx,ts,tsx,json,css}'",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "codegen": "openapi-typescript libs/api/schema/sophia-swagger.json -o libs/api/generated/sophia.ts --default-non-nullable --properties-required-by-default"
  },
  "dependencies": {
    "@blocknote/core": "^0.31.1",
    "@blocknote/mantine": "^0.31.1",
    "@blocknote/react": "^0.31.1",
    "@tailwindcss/postcss": "^4.2.2",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dayjs": "^1.11.19",
    "lucide-react": "^1.7.0",
    "next": "16.1.1",
    "openapi-fetch": "^0.17.0",
    "postcss": "^8.5.8",
    "prettier": "^3.7.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.69.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.1",
    "@storybook/nextjs": "^10.2.8",
    "@storybook/react": "^10.2.8",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-storybook": "^10.2.8",
    "openapi-typescript": "^7.13.0",
    "storybook": "^10.2.8",
    "typescript": "^5.9.3"
  }
